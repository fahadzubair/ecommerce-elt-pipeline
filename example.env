# Copy to `.env` and fill in.  cp example.env .env

# --- AWS ---
export AWS_ACCESS_KEY_ID=<key id>
export AWS_SECRET_ACCESS_KEY=<secret key>
export AWS_DEFAULT_REGION=<e.g. us-east-1>
export S3_RAW_BUCKET=<bucket name>
export S3_RAW_PREFIX=<e.g. raw>

# --- Snowflake ---
export SNOWFLAKE_ACCOUNT=<ORG-ACCOUNT>
export SNOWFLAKE_USER=<username>
export SNOWFLAKE_PASSWORD=<password>
export SNOWFLAKE_ROLE=<e.g. ACCOUNTADMIN>
export SNOWFLAKE_WAREHOUSE=<e.g. ecomm_dw>
export SNOWFLAKE_DATABASE=<e.g. ecomm_dw>
export SNOWFLAKE_SCHEMA=<e.g. raw>
